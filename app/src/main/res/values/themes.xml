<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Material Design 3 -->
    <style name="Theme.DeviceVibrationTester" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Material Design 3 Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        
        <!-- Material Design 3 Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary</item>
        
        <!-- Material Design 3 Surface Colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface</item>
        
        <!-- Status bar and navigation -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/primary</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Material Design 3 Attributes -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="l">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="l">@color/background</item>
        
        <!-- Custom widget styles -->
        <item name="cardViewStyle">@style/Widget.CardView</item>
        <item name="spinnerStyle">@style/Widget.Spinner</item>
        <item name="switchStyle">@style/CustomSwitch</item>
        
        <!-- Material Design 3 Shape Attributes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.LargeComponent</item>
    </style>
    
    <!-- Shape Appearances for Material Design 3 -->
    <style name="ShapeAppearance.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>
