{
  "expo": {
    "name": "CorrodedProxyV2 Mobile",
    "slug": "corrodedproxyv2-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "corrodedproxy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a14"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.thelonedrifter.corrodedproxyv2",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a1a14"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "0d72c48b-83af-4fcf-9fbe-e65d644a6a19"
      }
    },
    "owner": "thelonedrifter"
  }
}
