<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/download_item_bg"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/download_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/background_input"
            android:src="@drawable/ic_download"
            android:tint="@color/text_primary"
            android:padding="8dp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/download_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="4dp" />

        <ProgressBar
            android:id="@+id/download_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/download_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/download_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/earth_accent"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />

        </LinearLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_cancel_download"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/nav_button_background"
        android:src="@drawable/ic_close"
        android:tint="@color/text_secondary"
        android:contentDescription="Cancel"
        android:padding="4dp"
        android:layout_marginStart="8dp" />

</LinearLayout>
