<resources>
    <!-- Material Design 3 Component Styles -->
    
    <!-- Modern card style with Material Design 3 -->
    <style name="Widget.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">@dimen/stroke_width</item>
        <item name="rippleColor">@color/primary_container</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MediumComponent</item>
    </style>
    
    <!-- Modern spinner style -->
    <style name="Widget.Spinner" parent="Widget.Material3.AutoCompleteTextView.ExposedDropdownMenu">
        <item name="android:background">@drawable/glass_spinner_background</item>
        <item name="android:popupBackground">@drawable/glass_card_background</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textAppearance">@style/TextAppearance.DeviceLabel</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="boxStrokeWidth">@dimen/stroke_width</item>
        <item name="boxCornerRadiusTopStart">@dimen/spinner_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/spinner_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/spinner_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/spinner_corner_radius</item>
    </style>
    
    <!-- Modern switch style -->
    <style name="CustomSwitch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="trackTint">@color/surface_variant</item>
        <item name="thumbTint">@color/secondary</item>
        <item name="trackCornerRadius">@dimen/switch_corner_radius</item>
        <item name="thumbElevation">@dimen/switch_elevation</item>
    </style>
    
    <!-- Text appearances with Material Design 3 typography -->
    <style name="TextAppearance.StatusText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">@dimen/status_text_size</item>
        <item name="android:fontFamily">@string/font_family_medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    
    <style name="TextAppearance.TitleText" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:fontFamily">@string/font_family_medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    
    <style name="TextAppearance.SubtitleText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_secondary</item>
        <item name="android:textSize">@dimen/subtitle_text_size</item>
        <item name="android:fontFamily">@string/font_family_regular</item>
        <item name="android:letterSpacing">0.01</item>
    </style>
    
    <style name="TextAppearance.DeviceLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">@dimen/device_label_text_size</item>
        <item name="android:fontFamily">@string/font_family_medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>
</resources>
