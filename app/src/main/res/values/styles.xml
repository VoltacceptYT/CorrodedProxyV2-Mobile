<resources>
    <!-- Custom styles for Device Vibration Tester - Modern Glass Effect -->
    
    <!-- Modern card style with liquid glass effect -->
    <style name="Widget.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">12dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="rippleColor">@color/primary_variant</item>
    </style>
    
    <!-- Modern spinner style -->
    <style name="Widget.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/glass_spinner_background</item>
        <item name="android:popupBackground">@drawable/glass_card_background</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Modern switch style -->
    <style name="CustomSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackTint">@color/surface_variant</item>
        <item name="thumbTint">@color/secondary</item>
        <item name="trackCornerRadius">12dp</item>
    </style>
    
    <!-- Status text style -->
    <style name="TextAppearance.StatusText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Title text style -->
    <style name="TextAppearance.TitleText" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Subtitle text style -->
    <style name="TextAppearance.SubtitleText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Device label style -->
    <style name="TextAppearance.DeviceLabel" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
