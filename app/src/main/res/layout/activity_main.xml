<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Main content area -->
    <LinearLayout
        android:id="@+id/main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Tab Bar -->
        <LinearLayout
            android:id="@+id/tab_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tab_bar_height"
            android:orientation="horizontal"
            android:background="@color/background_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tab_recycler"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never"
                tools:listitem="@layout/item_tab" />

            <ImageButton
                android:id="@+id/btn_add_tab"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_add"
                android:contentDescription="@string/add_tab"
                android:tint="@color/text_primary"
                android:padding="6dp"
                android:layout_marginStart="4dp" />

            <ImageButton
                android:id="@+id/btn_tab_count"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_background"
                android:contentDescription="@string/tab_count"
                android:layout_marginStart="2dp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Address/Nav Bar -->
        <LinearLayout
            android:id="@+id/nav_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:background="@color/background_secondary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_home"
                android:layout_width="@dimen/nav_button_size"
                android:layout_height="@dimen/nav_button_size"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/home"
                android:tint="@color/text_primary"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/nav_button_size"
                android:layout_height="@dimen/nav_button_size"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/go_back"
                android:tint="@color/text_primary"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="@dimen/nav_button_size"
                android:layout_height="@dimen/nav_button_size"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_forward"
                android:contentDescription="@string/go_forward"
                android:tint="@color/text_primary"
                android:padding="10dp" />

            <!-- Search/URL bar -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <EditText
                    android:id="@+id/search_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/search_bar_background"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:hint="@string/search_placeholder"
                    android:textSize="14sp"
                    android:imeOptions="actionGo|flagNoExtractUi"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:paddingStart="44dp"
                    android:paddingEnd="12dp"
                    android:selectAllOnFocus="true" />

                <ImageView
                    android:id="@+id/search_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_secondary"
                    android:importantForAccessibility="no" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_reload"
                android:layout_width="@dimen/nav_button_size"
                android:layout_height="@dimen/nav_button_size"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_refresh"
                android:contentDescription="@string/reload"
                android:tint="@color/text_primary"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="@dimen/nav_button_size"
                android:layout_height="@dimen/nav_button_size"
                android:background="@drawable/nav_button_background"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="@string/settings"
                android:tint="@color/text_primary"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Progress Bar (below nav) -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressDrawable="@drawable/progress_bar_drawable"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <!-- WebView container -->
        <FrameLayout
            android:id="@+id/webview_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- New Tab Page (shown when no URL loaded) -->
            <include
                android:id="@+id/new_tab_page"
                layout="@layout/layout_new_tab"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- Find In Page Bar (overlaid at top when visible) -->
    <LinearLayout
        android:id="@+id/find_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/background_settings"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_anchor="@id/coordinator_layout"
        app:layout_anchorGravity="top">

        <EditText
            android:id="@+id/find_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/find_bar_input_bg"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:hint="@string/find_in_page_hint"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

        <TextView
            android:id="@+id/find_results_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="60dp"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btn_find_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_button_background"
            android:src="@drawable/ic_arrow_up"
            android:tint="@color/text_primary"
            android:contentDescription="Previous"
            android:padding="6dp"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btn_find_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_button_background"
            android:src="@drawable/ic_arrow_down"
            android:tint="@color/text_primary"
            android:contentDescription="Next"
            android:padding="6dp"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btn_find_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_button_background"
            android:src="@drawable/ic_close"
            android:tint="@color/text_primary"
            android:contentDescription="@string/close"
            android:padding="6dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Context Menu (positioned dynamically) -->
    <include
        android:id="@+id/context_menu"
        layout="@layout/layout_context_menu"
        android:visibility="gone" />

    <!-- Download bar (overlay) -->
    <include
        android:id="@+id/download_bar"
        layout="@layout/layout_download_bar"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
