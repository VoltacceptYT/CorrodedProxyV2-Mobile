<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#222"
    tools:context=".MainActivity">

    <!-- Top Navigation Bar with Tabs -->
    <LinearLayout
        android:id="@+id/top_nav"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#333"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="0dp">

        <!-- Left side: Tabs and Add Tab -->
        <HorizontalScrollView
            android:id="@+id/tabs_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabs_layout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="bottom" />

        </HorizontalScrollView>

        <!-- Add Tab Button -->
        <ImageButton
            android:id="@+id/add_tab_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:background="#353535"
            android:src="@drawable/ic_add"
            android:tint="#fff"
            android:contentDescription="Add tab" />

        <!-- Drag Area (flexible space) -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/settings_btn"
            android:layout_width="46dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_settings"
            android:tint="#fff"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Navigation Bar with URL/Search -->
    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#333"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Home Button -->
            <ImageButton
                android:id="@+id/home_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_home"
                android:tint="#fff"
                android:contentDescription="Home" />

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/back_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_arrow_back"
                android:tint="#fff"
                android:contentDescription="Back" />

            <!-- Forward Button -->
            <ImageButton
                android:id="@+id/forward_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_arrow_forward"
                android:tint="#fff"
                android:contentDescription="Forward" />

            <!-- Reload Button -->
            <ImageButton
                android:id="@+id/reload_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_refresh"
                android:tint="#fff"
                android:contentDescription="Reload" />

            <!-- URL/Search Bar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="#4545459e"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="0dp"
                android:backgroundTint="#4545459e">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginLeft="12dp"
                    android:src="@drawable/ic_search"
                    android:tint="#aaa" />

                <EditText
                    android:id="@+id/url_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search or enter a new URL"
                    android:textColorHint="#aaa"
                    android:textColor="#fff"
                    android:textSize="14sp"
                    android:padding="0dp"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="16dp"
                    android:inputType="textUri"
                    android:imeOptions="actionGo"
                    android:singleLine="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- WebView Container -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#222">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp" />

    </FrameLayout>

</LinearLayout>
