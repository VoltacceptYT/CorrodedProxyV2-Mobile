<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/context_menu_container"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/context_menu_background"
    android:elevation="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/menu_item_back"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_forward"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_forward"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Forward"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_reload"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reload"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/menu_item_share"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_share"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_copy_link"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_copy"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Copy link"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_find"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Find in page"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_new_tab"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_add"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New tab"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/menu_item_bookmark"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_bookmark"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add bookmark"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_settings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/context_menu_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_settings"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter" />
    </LinearLayout>

</LinearLayout>
