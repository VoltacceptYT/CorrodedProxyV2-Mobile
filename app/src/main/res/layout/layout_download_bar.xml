<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/download_bar_root"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/context_menu_background"
    android:elevation="12dp"
    android:layout_gravity="end|top"
    android:layout_marginTop="110dp"
    android:layout_marginEnd="16dp">

    <LinearLayout
        android:id="@+id/download_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/background_buttons"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Downloads"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter" />

        <ImageButton
            android:id="@+id/btn_toggle_downloads"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/nav_button_background"
            android:src="@drawable/ic_arrow_down"
            android:tint="@color/text_primary"
            android:contentDescription="Toggle"
            android:padding="4dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/downloads_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="280dp"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:overScrollMode="never" />

</LinearLayout>
