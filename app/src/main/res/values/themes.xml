<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.DeviceVibrationTester" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/primary_dark</item>
        <!-- Window and background colors. -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Rounded corners and modern styling. -->
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenBackground">@color/background_dark</item>
        <!-- Custom widget styles. -->
        <item name="cardViewStyle">@style/Widget.CardView</item>
        <item name="spinnerStyle">@style/Widget.Spinner</item>
        <item name="switchStyle">@style/CustomSwitch</item>
    </style>
</resources>
