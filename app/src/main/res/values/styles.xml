<resources>
    <!-- Custom styles for Device Vibration Tester -->
    
    <!-- Modern card style with liquid glass effect -->
    <style name="Widget.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Modern spinner style -->
    <style name="Widget.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/spinner_background</item>
        <item name="android:popupBackground">@drawable/spinner_dropdown_background</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Modern switch style -->
    <style name="CustomSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackTint">@color/surface</item>
        <item name="thumbTint">@color/secondary</item>
    </style>
    
    <!-- Status text style -->
    <style name="TextAppearance.StatusText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <!-- Title text style -->
    <style name="TextAppearance.TitleText" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <!-- Subtitle text style -->
    <style name="TextAppearance.SubtitleText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/on_secondary</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <!-- Device label style -->
    <style name="TextAppearance.DeviceLabel" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
