<resources>
    <!-- Custom styles for VBRT - Hot Pink Theme -->
    
    <!-- Modern card style with hot pink theme -->
    <style name="Widget.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="strokeColor">@color/border_dark</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/primary</item>
    </style>
    
    <!-- Modern switch style -->
    <style name="CustomSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackTint">@color/switch_track</item>
        <item name="thumbTint">@color/switch_thumb</item>
        <item name="trackCornerRadius">12dp</item>
    </style>
    
    <!-- Status text style -->
    <style name="TextAppearance.StatusText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Title text style -->
    <style name="TextAppearance.TitleText" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Subtitle text style -->
    <style name="TextAppearance.SubtitleText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Device label style -->
    <style name="TextAppearance.DeviceLabel" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
